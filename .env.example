# Spotify app credentials for the Web Playback SDK (PKCE flow, no client secret).
# Create an app at https://developer.spotify.com/dashboard, add the redirect URI
# below to its settings, then copy this file to `.env` and fill in the client ID.
# Use 127.0.0.1 (not localhost); Spotify rejects localhost redirect URIs.
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
